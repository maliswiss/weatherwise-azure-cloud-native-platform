# =============================================================================
# WeatherWise Frontend - Environment-Variablen
# =============================================================================
# Hinweis: Vite-Variablen mit VITE_-Präfix landen im Browser-Bundle.
# Daher steht hier KEIN Geheimnis - nur die öffentliche Backend-URL.
#
# Der OpenWeatherMap-API-Key liegt im Backend (Azure Key Vault) und
# erreicht den Browser zu keinem Zeitpunkt.
# =============================================================================

# Basis-URL des eigenen Backends
# Lokal:      http://localhost:8000
# Dev-Cloud:  https://weatherwise-backend-dev.azurecontainerapps.io
# Prod-Cloud: https://weatherwise-backend-prod.azurecontainerapps.io
VITE_API_BASE_URL=http://localhost:8000
