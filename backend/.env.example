# =============================================================================
# WeatherWise Backend - Environment-Variablen
# =============================================================================
# Diese Datei ist eine VORLAGE. Kopiere sie zu .env und trage echte Werte ein.
# Die echte .env-Datei wird NIE in Git eingecheckt (siehe .gitignore).
#
# In Production werden diese Werte aus Azure Key Vault geladen.
# =============================================================================

# OpenWeatherMap API-Key
# Kostenlos registrieren unter: https://openweathermap.org/api
OPENWEATHER_API_KEY=dein_api_key_hier

# Optional: API-Basis-URL (Default ist die offizielle OpenWeatherMap-URL)
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# Redis-Verbindung (im Docker-Compose-Netzwerk per Service-Name "redis")
REDIS_URL=redis://redis:6379/0

# Cache-Time-to-Live in Sekunden (Default: 600 = 10 Minuten)
CACHE_TTL_SECONDS=600

# Erlaubte CORS-Origins, kommasepariert
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# Umgebungs-Label (development, staging, production)
APP_ENV=development
